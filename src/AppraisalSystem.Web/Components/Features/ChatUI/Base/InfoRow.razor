<div class="space-y-0.5 rounded-lg px-2.5 py-1.5 bg-muted/5" style="background: var(--muted, rgba(0,0,0,0.04));">
    <span class="text-[0.6rem] font-semibold uppercase tracking-wider text-muted-foreground/50">@Label</span>
    <p class="text-xs leading-relaxed text-foreground/90">@Value</p>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
}