
@using AppraisalSystem.Application.Features.ChatUI
@using AppraisalSystem.Web.Components.Features.ChatUI.Base
@using AppraisalSystem.Web.Services

@implements IDisposable

<aside class="@($"max-h-svh min-h-svh border-l bg-muted/30 transition-all duration-300 overflow-hidden {(_isOpen ? "w-[400px] opacity-100" : "w-0 opacity-0")}")">
    @if (_listing is not null)
    {
        <div class="flex h-full flex-col">
            <div class="flex shrink-0 items-center gap-2 border-b px-4 py-3">
                <span class="text-sm font-semibold">📋 Detail Property</span>
                <button type="button" @onclick="PropertyAsideService.Close" class="ml-auto rounded p-1 text-muted-foreground hover:bg-muted hover:text-foreground" aria-label="Tutup">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <path d="M18 6 6 18" /><path d="m6 6 12 12" />
                    </svg>
                </button>
            </div>

            <div class="scrollbar flex-1 overflow-y-auto p-4">
                @if (!string.IsNullOrEmpty(_listing.ImageUrl))
                {
                    <img src="@_listing.ImageUrl" alt="@_listing.Title" class="mb-4 w-full rounded-lg object-cover" />
                }

                <h2 class="mb-2 text-base font-semibold leading-snug">@(!string.IsNullOrEmpty(_listing.Title) ? _listing.Title : "Properti")</h2>
                @if (!string.IsNullOrEmpty(_listing.Price))
                {
                    <p class="mb-4 text-lg font-bold text-primary">@_listing.Price</p>
                }

                <Card>
                    <CardContent class="space-y-3 p-4">
                        @if (!string.IsNullOrEmpty(_listing.Lt) || !string.IsNullOrEmpty(_listing.Lb) || !string.IsNullOrEmpty(_listing.Kt) || !string.IsNullOrEmpty(_listing.Km))
                        {
                            <div class="grid grid-cols-2 gap-2">
                                @if (!string.IsNullOrEmpty(_listing.Lt)) { <Spec Label="LT" Value="@(_listing.Lt + " m²")" /> }
                                @if (!string.IsNullOrEmpty(_listing.Lb)) { <Spec Label="LB" Value="@(_listing.Lb + " m²")" /> }
                                @if (!string.IsNullOrEmpty(_listing.Kt)) { <Spec Label="KT" Value="@_listing.Kt" /> }
                                @if (!string.IsNullOrEmpty(_listing.Km)) { <Spec Label="KM" Value="@_listing.Km" /> }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_listing.Description))
                        {
                            <div>
                                <p class="mb-1 text-xs font-medium text-muted-foreground">Deskripsi</p>
                                <p class="text-sm">@_listing.Description</p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_listing.AddressDetail))
                        {
                            <div>
                                <p class="mb-1 text-xs font-medium text-muted-foreground">Alamat</p>
                                <p class="text-sm">@_listing.AddressDetail</p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_listing.Certificate)) { <InfoRow Label="Sertifikat" Value="@_listing.Certificate" /> }
                        @if (!string.IsNullOrEmpty(_listing.Floor)) { <InfoRow Label="Lantai" Value="@_listing.Floor" /> }
                        @if (!string.IsNullOrEmpty(_listing.Electricity)) { <InfoRow Label="Listrik" Value="@_listing.Electricity" /> }
                        @if (!string.IsNullOrEmpty(_listing.Furnished)) { <InfoRow Label="Furnish" Value="@_listing.Furnished" /> }
                        @if (!string.IsNullOrEmpty(_listing.Facing)) { <InfoRow Label="Hadap" Value="@_listing.Facing" /> }
                        @if (!string.IsNullOrEmpty(_listing.Transaction)) { <InfoRow Label="Transaksi" Value="@_listing.Transaction" /> }
                        @if (!string.IsNullOrEmpty(_listing.Garage)) { <InfoRow Label="Garasi" Value="@_listing.Garage" /> }
                        @if (!string.IsNullOrEmpty(_listing.ListedDate)) { <InfoRow Label="Terdaftar" Value="@_listing.ListedDate" /> }
                    </CardContent>
                </Card>

                @if (!string.IsNullOrEmpty(_listing.Url))
                {
                    <a href="@_listing.Url" target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/80">
                        🔗 Buka di Brighton
                    </a>
                }
            </div>
        </div>
    }
</aside>

@code {
    [Inject]
    private PropertyAsideService PropertyAsideService { get; set; } = default!;

    private PropertyListing? _listing;
    private bool _isOpen;

    protected override void OnInitialized()
    {
        PropertyAsideService.OnChange += OnAsideChanged;
        (_listing, _isOpen) = (PropertyAsideService.CurrentListing, PropertyAsideService.IsOpen);
    }

    private void OnAsideChanged(PropertyListing? listing, bool open)
    {
        _listing = listing;
        _isOpen = open;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PropertyAsideService.OnChange -= OnAsideChanged;
    }
}