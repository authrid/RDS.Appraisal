@using AppraisalSystem.Application.Features.ChatUI
<div class="rounded-lg border border-primary/20" style="background: var(--primary, rgba(0,0,0,0.04));">
    <button type="button" @onclick="Toggle" class="flex w-full items-center gap-2 px-3 py-2 text-left">
        <span class="text-xs font-medium">🔍 Filter Parameter</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="@($"ml-auto size-3.5 text-muted-foreground transition-transform duration-200 {(_expanded ? "rotate-180" : "")}")">
            <path d="m6 9 6 6 6-6" />
        </svg>
    </button>
    @if (_expanded)
    {
        <div class="grid grid-cols-2 gap-2 border-t px-3 py-2">
            <label class="flex flex-col gap-0.5">
                <span class="text-[0.6rem] font-medium text-muted-foreground">LT Min (m²)</span>
                <input type="number" min="0" @bind="Params.LtMin" placeholder="—" class="h-7 rounded border bg-background px-2 text-xs outline-none focus:border-primary/50" />
            </label>
            <label class="flex flex-col gap-0.5">
                <span class="text-[0.6rem] font-medium text-muted-foreground">LT Max (m²)</span>
                <input type="number" min="0" @bind="Params.LtMax" placeholder="—" class="h-7 rounded border bg-background px-2 text-xs outline-none focus:border-primary/50" />
            </label>
            <label class="flex flex-col gap-0.5">
                <span class="text-[0.6rem] font-medium text-muted-foreground">LB Min (m²)</span>
                <input type="number" min="0" @bind="Params.LbMin" placeholder="—" class="h-7 rounded border bg-background px-2 text-xs outline-none focus:border-primary/50" />
            </label>
            <label class="flex flex-col gap-0.5">
                <span class="text-[0.6rem] font-medium text-muted-foreground">LB Max (m²)</span>
                <input type="number" min="0" @bind="Params.LbMax" placeholder="—" class="h-7 rounded border bg-background px-2 text-xs outline-none focus:border-primary/50" />
            </label>
            <label class="flex flex-col gap-0.5">
                <span class="text-[0.6rem] font-medium text-muted-foreground">KT (Kamar Tidur)</span>
                <input type="number" min="0" @bind="Params.Kt" placeholder="—" class="h-7 rounded border bg-background px-2 text-xs outline-none focus:border-primary/50" />
            </label>
            <label class="flex flex-col gap-0.5">
                <span class="text-[0.6rem] font-medium text-muted-foreground">KM (Kamar Mandi)</span>
                <input type="number" min="0" @bind="Params.Km" placeholder="—" class="h-7 rounded border bg-background px-2 text-xs outline-none focus:border-primary/50" />
            </label>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public ProcessCertificateRefineParams Params { get; set; } = default!;
    [Parameter] public EventCallback<ProcessCertificateRefineParams> ParamsChanged { get; set; }

    private bool _expanded;

    private void Toggle() => _expanded = !_expanded;
}