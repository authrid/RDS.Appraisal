@using AppraisalSystem.Application.Features.ChatUI
@using AppraisalSystem.Web.Components.Features.ChatUI.Base
@inject HttpClient Http

<Card Class="overflow-hidden border-primary/20">
    <CardContent Class="p-3">
        <button type="button" @onclick="ToggleExpanded" class="flex w-full items-center gap-2 text-left">
            <span class="text-sm font-medium">🔍 Refine Search Parameters</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="@($"ml-auto size-4 text-muted-foreground transition-transform duration-200 {(_expanded ? "rotate-180" : "")}")">
                <path d="m6 9 6 6 6-6" />
            </svg>
        </button>

        @if (_expanded)
        {
            <div class="mt-3 space-y-3 border-t pt-3">
                <label class="flex flex-col gap-1">
                    <span class="text-xs font-medium text-muted-foreground">Address</span>
                    <input @bind="_fields.Address" placeholder="Full address..." class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                </label>

                <div class="grid grid-cols-2 gap-2">
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">Certificate Type</span>
                        <select @bind="_fields.CertificateType" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20">
                            @foreach (var opt in CertificateOptions)
                            {
                                <option value="@opt">@opt</option>
                            }
                        </select>
                    </label>
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">Transaction Type</span>
                        <select @bind="_fields.TransactionType" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20">
                            @foreach (var opt in TransactionOptions)
                            {
                                <option value="@opt.Value">@opt.Label</option>
                            }
                        </select>
                    </label>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">City (slug)</span>
                        <input @bind="_fields.City" placeholder="city-slug" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                    </label>
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">District (slug)</span>
                        <input @bind="_fields.District" placeholder="district-slug" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                    </label>
                </div>

                <label class="flex flex-col gap-1">
                    <span class="text-xs font-medium text-muted-foreground">Keyword</span>
                    <input @bind="_fields.Keyword" placeholder="Search keyword..." class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                </label>

                <div class="grid grid-cols-2 gap-2">
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">KT (Kamar Tidur)</span>
                        <input @bind="_fields.Kt" placeholder="e.g. 2" type="number" min="0" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                    </label>
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">KM (Kamar Mandi)</span>
                        <input @bind="_fields.Km" placeholder="e.g. 1" type="number" min="0" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                    </label>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">LT Min (m²)</span>
                        <input @bind="_fields.LtMin" placeholder="e.g. 60" type="number" min="0" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                    </label>
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">LT Max (m²)</span>
                        <input @bind="_fields.LtMax" placeholder="e.g. 200" type="number" min="0" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                    </label>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">LB Min (m²)</span>
                        <input @bind="_fields.LbMin" placeholder="e.g. 36" type="number" min="0" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                    </label>
                    <label class="flex flex-col gap-1">
                        <span class="text-xs font-medium text-muted-foreground">LB Max (m²)</span>
                        <input @bind="_fields.LbMax" placeholder="e.g. 150" type="number" min="0" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20" />
                    </label>
                </div>

                <label class="flex flex-col gap-1">
                    <span class="text-xs font-medium text-muted-foreground">Hadap</span>
                    <select @bind="_fields.Hadap" class="h-8 rounded-md border bg-background px-2.5 text-xs outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20">
                        @foreach (var opt in HadapOptions)
                        {
                            <option value="@opt">@(string.IsNullOrEmpty(opt) ? "— Any —" : opt)</option>
                        }
                    </select>
                </label>

                <button @onclick="HandleSubmit" disabled="@_loading" class="btn btn-primary w-full gap-2 d-inline-flex align-items-center justify-content-center" style="height: 32px; font-size: 0.875rem;">
                    @if (_loading)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 animate-spin">
                            <path d="M21 12a9 9 0 1 1-6.219-8.56" />
                        </svg>
                    }
                    @(_loading ? "Searching..." : "Search with these parameters")
                </button>
            </div>
        }
    </CardContent>
</Card>

@code {
    [Parameter, EditorRequired]
    public AddressInfo AddressInfo { get; set; } = default!;

    [Parameter]
    public CrawlFormFields? DefaultValues { get; set; }

    [Parameter]
    public EventCallback<(List<PropertyListing> Listings, string Url, int? Total, string? Error, CrawlFormFields Fields)> OnResult { get; set; }

    private bool _expanded;
    private bool _loading;
    private CrawlFormFields _fields = new();

    private static readonly List<(string Value, string Label)> TransactionOptions = new()
    {
        ("dijual", "Dijual (For Sale)"),
        ("disewa", "Disewa (For Rent)"),
    };

    private static readonly List<string> CertificateOptions = new() { "SHM", "HGB", "HGU", "HP" };

    private static readonly List<string> HadapOptions = new()
    {
        "", "Utara", "Selatan", "Timur", "Barat",
        "Timur Laut", "Tenggara", "Barat Laut", "Barat Daya",
    };

    private static string Slugify(string text)
    {
        return System.Text.RegularExpressions.Regex.Replace(
            text.ToLower().Trim(),
            @"[^\w\s-]", ""
        ).Replace(" ", "-").Replace("_", "-");
    }

    private CrawlFormFields ComputeInitialFields()
    {
        var defaultCity = !string.IsNullOrEmpty(AddressInfo.City) ? Slugify(AddressInfo.City) : "";
        var defaultDistrict = !string.IsNullOrEmpty(AddressInfo.District) ? Slugify(AddressInfo.District) : "";
        var defaultKeyword = AddressInfo.SubDistrict ?? "";
        var defaultAddress = string.Join(", ", new[]
        {
            AddressInfo.SubDistrict,
            AddressInfo.District,
            AddressInfo.City,
            AddressInfo.Province
        }.Where(s => !string.IsNullOrEmpty(s)));

        return new CrawlFormFields
        {
            Address = DefaultValues?.Address ?? defaultAddress,
            CertificateType = DefaultValues?.CertificateType ?? "SHM",
            Keyword = DefaultValues?.Keyword ?? defaultKeyword,
            Kt = DefaultValues?.Kt ?? "",
            Km = DefaultValues?.Km ?? "",
            LtMin = DefaultValues?.LtMin ?? "70",
            LtMax = DefaultValues?.LtMax ?? "100",
            LbMin = DefaultValues?.LbMin ?? "",
            LbMax = DefaultValues?.LbMax ?? "",
            Hadap = DefaultValues?.Hadap ?? "",
            City = DefaultValues?.City ?? defaultCity,
            District = DefaultValues?.District ?? defaultDistrict,
            TransactionType = DefaultValues?.TransactionType ?? "dijual",
        };
    }

    protected override void OnInitialized()
    {
        _fields = ComputeInitialFields();
    }

    protected override void OnParametersSet()
    {
        _fields = ComputeInitialFields();
    }

    private void ToggleExpanded()
    {
        _expanded = !_expanded;
    }

    private async Task HandleSubmit()
    {
        _loading = true;
        var submittedFields = new CrawlFormFields
        {
            Address = _fields.Address,
            CertificateType = _fields.CertificateType,
            Keyword = _fields.Keyword,
            Kt = _fields.Kt,
            Km = _fields.Km,
            LtMin = _fields.LtMin,
            LtMax = _fields.LtMax,
            LbMin = _fields.LbMin,
            LbMax = _fields.LbMax,
            Hadap = _fields.Hadap,
            City = _fields.City,
            District = _fields.District,
            TransactionType = _fields.TransactionType,
        };

        try
        {
            var payload = new
            {
                address = submittedFields.Address,
                certificate_type = submittedFields.CertificateType,
                keyword = submittedFields.Keyword,
                kt = submittedFields.Kt,
                km = submittedFields.Km,
                lt_min = submittedFields.LtMin,
                lt_max = submittedFields.LtMax,
                lb_min = submittedFields.LbMin,
                lb_max = submittedFields.LbMax,
                hadap = submittedFields.Hadap,
                city = submittedFields.City,
                district = submittedFields.District,
                transaction_type = submittedFields.TransactionType,
            };

            var response = await Http.PostAsJsonAsync("api/crawl-direct", payload);
            var result = await response.Content.ReadFromJsonAsync<CrawlDirectResult>();

            var crawlData = result?.CrawlResult ?? result;
            if ((result?.Success == true || crawlData?.Success == true) && crawlData is not null)
            {
                await OnResult.InvokeAsync((crawlData.Listings ?? [], crawlData.Url ?? "", crawlData.TotalListings, crawlData.Error, submittedFields));
            }
            else
            {
                await OnResult.InvokeAsync(([], "", null, crawlData?.Error ?? "Unknown error", submittedFields));
            }
        }
        catch (Exception ex)
        {
            await OnResult.InvokeAsync(([], "", null, ex.Message, submittedFields));
        }
        finally
        {
            _loading = false;
        }
    }
}