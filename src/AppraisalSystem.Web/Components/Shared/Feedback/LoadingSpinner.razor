@if (Visible)
{
    <div class="inline-flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-500">
        <div class="h-4 w-4 animate-spin rounded-full border-2 border-slate-300 border-t-blue-500"></div>
        <span>@Text</span>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Text { get; set; } = "Memuat data...";
}