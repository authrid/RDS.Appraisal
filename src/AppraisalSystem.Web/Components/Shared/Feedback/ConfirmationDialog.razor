@if (Open)
{
    <div class="fixed inset-0 z-[100] grid place-items-center bg-slate-900/40 p-4">
        <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-5 shadow-2xl">
            <h3 class="mb-2 text-lg font-bold text-slate-700">@Title</h3>
            <p class="text-sm text-slate-500">@Message</p>
            <div class="mt-5 flex justify-end gap-2">
                <BaseButton Variant="secondary" OnClick="CancelAsync">@CancelText</BaseButton>
                <BaseButton Variant="danger" OnClick="ConfirmAsync">@ConfirmText</BaseButton>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public string Title { get; set; } = "Konfirmasi";
    [Parameter] public string Message { get; set; } = "Apakah Anda yakin?";
    [Parameter] public string ConfirmText { get; set; } = "Ya";
    [Parameter] public string CancelText { get; set; } = "Batal";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private Task ConfirmAsync() => OnConfirm.InvokeAsync();

    private Task CancelAsync() => OnCancel.InvokeAsync();
}