@inject NavigationManager NavigationManager

<a href="@ResolvedHref"
   class="@BuildClass()"
   @attributes="AdditionalAttributes">
    @ChildContent
</a>

@code {
    [Parameter] public required string Href { get; set; }
    [Parameter] public string Variant { get; set; } = "primary";
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public string Class { get; set; } = string.Empty;
    [Parameter] public required RenderFragment ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedHref => NavigationManager.ToAppPath(Href);

    private string BuildClass()
    {
        var classes = new List<string>
        {
            "inline-flex items-center justify-center gap-1.5 border font-semibold no-underline transition focus:outline-none"
        };

        classes.Add(Size.ToLowerInvariant() switch
        {
            "xs" => "rounded-lg px-2.25 py-1 text-xs",
            "sm" => "rounded-lg px-2.75 py-1.5 text-sm",
            "lg" => "rounded-xl px-3.5 py-2.5 text-sm",
            _ => "rounded-lg px-3 py-2 text-sm"
        });

        classes.Add(Variant.ToLowerInvariant() switch
        {
            "primary" => "theme-btn-brand",
            "brand" => "theme-btn-brand",
            "secondary" => "theme-btn-secondary",
            "secondary-muted" => "theme-btn-secondary-muted",
            "info" => "theme-link-info",
            _ => "theme-btn-brand"
        });

        if (!string.IsNullOrWhiteSpace(Class))
        {
            classes.Add(Class);
        }

        return string.Join(" ", classes);
    }
}