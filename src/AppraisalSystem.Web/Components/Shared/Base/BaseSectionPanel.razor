<section class="rounded-2xl border bg-white p-4 shadow-sm @Class" style="border-color: var(--theme-panel-border); background: var(--theme-panel-bg);">
    @if (!string.IsNullOrWhiteSpace(Eyebrow) || !string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Subtitle) || RightContent is not null)
    {
        <div class="flex flex-col gap-3 border-b pb-3 sm:flex-row sm:items-start sm:justify-between" style="border-color: var(--theme-panel-border);">
            <div>
                @if (!string.IsNullOrWhiteSpace(Eyebrow))
                {
                    <p class="mb-0 text-[11px] font-extrabold uppercase tracking-[0.12em]" style="color: var(--brand-primary);">@Eyebrow</p>
                }
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h3 class="mt-1 mb-0 text-base font-bold" style="color: var(--theme-text-strong);">@Title</h3>
                }
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <p class="mt-1 mb-0 text-sm" style="color: var(--theme-text-muted);">@Subtitle</p>
                }
            </div>

            @if (RightContent is not null)
            {
                <div class="sm:pl-4">
                    @RightContent
                </div>
            }
        </div>
    }

    <div class="mt-4">
        @ChildContent
    </div>
</section>

@code {
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string Class { get; set; } = string.Empty;
    [Parameter] public RenderFragment? RightContent { get; set; }
    [Parameter] public required RenderFragment ChildContent { get; set; }
}
