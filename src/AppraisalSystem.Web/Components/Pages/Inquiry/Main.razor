@page "/inquiry"
@attribute [Authorize]
@using AppraisalSystem.Application.Common
@using AppraisalSystem.Application.Dtos
@using AppraisalSystem.Application.Interfaces

@inject IAppraisalService AppraisalService
@inject IReferenceDataService ReferenceService

<PageTitle>Inquiry</PageTitle>

<BaseCard Title="Inquiry" Subtitle="Pencarian data appraisal untuk pengecekan readonly." Class="w-full">
    <div class="space-y-5">
        <div class="grid grid-cols-1 gap-4 xl:grid-cols-[1.2fr_0.8fr]">
            <div class="rounded-2xl border border-slate-200 bg-[radial-gradient(circle_at_top_left,_rgba(14,165,233,0.12),_transparent_36%),linear-gradient(180deg,#f8fbff_0%,#eff8ff_100%)] p-5">
                <p class="mb-1 text-[11px] font-extrabold uppercase tracking-[0.12em] text-cyan-600">Inquiry</p>
                <h3 class="mt-0 mb-2 text-xl font-extrabold text-slate-800">Pencarian data pengajuan</h3>
                <p class="mb-0 max-w-2xl text-sm leading-6 text-slate-600">Gunakan form untuk mencari berdasarkan No. Aplikasi, Nama, Jenis Jaminan, dan rentang tanggal aplikasi.</p>
            </div>

            <div class="grid grid-cols-1 gap-3 sm:grid-cols-3 xl:grid-cols-1">
                <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
                    <p class="mb-1 text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-400">Total Hasil</p>
                    <p class="mb-0 text-2xl font-extrabold text-slate-800">@_result.TotalItems</p>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
                    <p class="mb-1 text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-400">Tanggal Mulai</p>
                    <p class="mb-0 text-base font-bold text-slate-700">@DisplayDate(_applicationDateFrom)</p>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
                    <p class="mb-1 text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-400">Tanggal Akhir</p>
                    <p class="mb-0 text-base font-bold text-slate-700">@DisplayDate(_applicationDateTo)</p>
                </div>
            </div>
        </div>

        <BaseSectionPanel Eyebrow="Filter" Title="Form Pencarian" Subtitle="Isi filter sesuai kebutuhan lalu jalankan pencarian.">
            <div class="mx-auto w-full max-w-xl space-y-3">
                <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                    <BaseTextField Id="applicationNumber" Label="No. Aplikasi" @bind-Value="_applicationNumber" Placeholder="Masukkan nomor aplikasi" />
                    <BaseSearchListModalField Id="collateralSubtype"
                                              Label="Jenis Jaminan"
                                              Value="@_collateralSubtype"
                                              ValueChanged="OnCollateralSubtypeChanged"
                                              Options="@_collateralSubtypeOptions"
                                              Placeholder="Pilih Jenis Jaminan"
                                              ModalTitle="Pilih Jenis Jaminan"
                                              ModalSubtitle="Pilih dari daftar referensi jaminan." />
                </div>

                <BaseTextField Id="debtorName" Label="Nama" @bind-Value="_debtorName" Placeholder="Masukkan nama debitur" />

                <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                    <BaseFormInput Id="applicationDateFrom" Label="Tanggal Mulai">
                        <InputDate TValue="DateTime?" id="applicationDateFrom" @bind-Value="_applicationDateFrom" class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm text-slate-700 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-100" />
                    </BaseFormInput>

                    <BaseFormInput Id="applicationDateTo" Label="Tanggal Akhir">
                        <InputDate TValue="DateTime?" id="applicationDateTo" @bind-Value="_applicationDateTo" class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm text-slate-700 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-100" />
                    </BaseFormInput>
                </div>

                <div class="flex flex-col gap-2 sm:flex-row sm:justify-end">
                    <BaseButton Variant="brand" Size="lg" Class="w-full sm:w-auto" OnClick="SearchAsync">
                        <span class="inline-flex items-center gap-2">
                            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                                <path d="M3 5h14"></path>
                                <path d="M6 10h8"></path>
                                <path d="M8.5 15h3"></path>
                            </svg>
                            <span>Cari</span>
                        </span>
                    </BaseButton>

                    <BaseButton Variant="secondary" Size="lg" Class="w-full sm:w-auto" OnClick="ResetAsync">
                        <span class="inline-flex items-center gap-2">
                            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                                <path d="M15.5 8A5.5 5.5 0 1 0 17 12"></path>
                                <path d="M16 4.5v4h-4"></path>
                            </svg>
                            <span>Reset</span>
                        </span>
                    </BaseButton>
                </div>

            @if (HasActiveFilters())
            {
                <div class="mt-2 flex flex-wrap gap-2">
                    @if (!string.IsNullOrWhiteSpace(_applicationNumber))
                    {
                        <span class="rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700">No. Aplikasi: @_applicationNumber</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(_debtorName))
                    {
                        <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600">Nama: @_debtorName</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(_collateralSubtype))
                    {
                        <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">Jenis Jaminan: @_collateralSubtype</span>
                    }
                    @if (_applicationDateFrom.HasValue)
                    {
                        <span class="rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">Mulai: @DisplayDate(_applicationDateFrom)</span>
                    }
                    @if (_applicationDateTo.HasValue)
                    {
                        <span class="rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">Akhir: @DisplayDate(_applicationDateTo)</span>
                    }
                </div>
            }
            </div>
        </BaseSectionPanel>

        <LoadingSpinner Visible="_isLoading" />

        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <BaseAlert Variant="danger" Class="mb-3">
                Gagal memuat data inquiry. Detail: @_loadError
            </BaseAlert>
        }

        @if (_hasSearched && !_isLoading)
        {
            <BaseSectionPanel Eyebrow="Daftar Hasil" Title="Hasil Inquiry" Subtitle="@BuildResultsSubtitle()">
                <BaseTable TItem="AppraisalListItemDto" Items="_result.Items" ColSpan="9" EmptyText="Data tidak ditemukan">
                    <HeaderTemplate>
                        <BaseTableHeaderCell Class="w-16">No</BaseTableHeaderCell>
                        <BaseTableHeaderCell>No. Aplikasi</BaseTableHeaderCell>
                        <BaseTableHeaderCell>Segment</BaseTableHeaderCell>
                        <BaseTableHeaderCell>Nama</BaseTableHeaderCell>
                        <BaseTableHeaderCell>NIK/NPWP</BaseTableHeaderCell>
                        <BaseTableHeaderCell>No. Akta</BaseTableHeaderCell>
                        <BaseTableHeaderCell>DOB/Tgl Berdiri</BaseTableHeaderCell>
                        <BaseTableHeaderCell>Jenis Nasabah</BaseTableHeaderCell>
                        <BaseTableHeaderCell Align="center" Class="w-36">Action</BaseTableHeaderCell>
                    </HeaderTemplate>
                    <RowTemplate Context="item">
                        <BaseTableCell Tone="muted">@GetRowNumber(item)</BaseTableCell>
                        <BaseTableCell Tone="default">@DisplayValue(item.ApplicationNumber)</BaseTableCell>
                        <BaseTableCell>@DisplayValue(item.Segment)</BaseTableCell>
                        <BaseTableCell Tone="default">
                            <div class="font-semibold text-slate-700">@item.DebtorName</div>
                        </BaseTableCell>
                        <BaseTableCell>@DisplayValue(item.IdentityNumber)</BaseTableCell>
                        <BaseTableCell>@DisplayValue(item.DeedNumber)</BaseTableCell>
                        <BaseTableCell Tone="soft">@ResolveApplicantDate(item)</BaseTableCell>
                        <BaseTableCell Class="whitespace-nowrap">
                            <ApplicantTypeBadge Value="@item.ApplicantType" />
                        </BaseTableCell>
                        <BaseTableCell Align="center" Padding="compact" Class="whitespace-nowrap">
                            <BaseLinkButton Href="@BuildDetailHref(item.PublicId)" Variant="info" Size="sm" Class="min-w-[6.75rem] justify-center px-3">
                                <span class="inline-flex items-center justify-center gap-2">
                                    <span class="grid h-5 w-5 place-items-center rounded-full" style="background: color-mix(in srgb, var(--brand-primary) 14%, #ffffff); color: var(--brand-primary);">
                                        <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                                            <path d="M2.5 10s2.5-5 7.5-5 7.5 5 7.5 5-2.5 5-7.5 5-7.5-5-7.5-5z"></path>
                                            <circle cx="10" cy="10" r="2.2"></circle>
                                        </svg>
                                    </span>
                                    <span>Detail</span>
                                </span>
                            </BaseLinkButton>
                        </BaseTableCell>
                    </RowTemplate>
                </BaseTable>

                <BasePagination CurrentPage="@_pageNumber"
                                TotalPages="@_result.TotalPages"
                                TotalItems="@_result.TotalItems"
                                PageSize="@PageSize"
                                ItemLabel="aplikasi"
                                OnPrevious="PrevPage"
                                OnNext="NextPage" />
            </BaseSectionPanel>
        }
    </div>
</BaseCard>

@code {
    private bool _isLoading = false;
    private bool _hasSearched;
    private string _loadError = string.Empty;
    private string _applicationNumber = string.Empty;
    private string _debtorName = string.Empty;
    private string _collateralSubtype = string.Empty;
    private string[] _collateralSubtypeOptions = Array.Empty<string>();
    private DateTime? _applicationDateFrom;
    private DateTime? _applicationDateTo;
    private int _pageNumber = 1;
    private const int PageSize = 10;

    private PagedResult<AppraisalListItemDto> _result = new()
    {
        Items = Array.Empty<AppraisalListItemDto>(),
        TotalItems = 0,
        PageNumber = 1,
        PageSize = PageSize
    };

    protected override async Task OnInitializedAsync()
    {
        var items = await ReferenceService.GetCollateralSubtypesAsync();
        _collateralSubtypeOptions = items.Select(x => x.Label).ToArray();
    }

    private Task OnCollateralSubtypeChanged(string? value)
    {
        _collateralSubtype = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private async Task SearchAsync(MouseEventArgs _)
    {
        _pageNumber = 1;
        _hasSearched = true;
        await LoadAsync();
    }

    private async Task ResetAsync(MouseEventArgs _)
    {
        _applicationNumber = string.Empty;
        _debtorName = string.Empty;
        _collateralSubtype = string.Empty;
        _applicationDateFrom = null;
        _applicationDateTo = null;
        _pageNumber = 1;
        _hasSearched = false;
        _result = new PagedResult<AppraisalListItemDto>
        {
            Items = Array.Empty<AppraisalListItemDto>(),
            TotalItems = 0,
            PageNumber = 1,
            PageSize = PageSize
        };
        await Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = string.Empty;

        try
        {
            _result = await AppraisalService.GetPagedAsync(new AppraisalQueryDto
            {
                ApplicationNumber = _applicationNumber,
                DebtorName = _debtorName,
                CollateralSubtype = _collateralSubtype,
                ApplicationDateFromUtc = _applicationDateFrom,
                ApplicationDateToUtc = _applicationDateTo,
                PageNumber = _pageNumber,
                PageSize = PageSize
            });
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            _result = new PagedResult<AppraisalListItemDto>
            {
                Items = Array.Empty<AppraisalListItemDto>(),
                TotalItems = 0,
                PageNumber = 1,
                PageSize = PageSize
            };
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PrevPage()
    {
        if (_pageNumber <= 1)
        {
            return;
        }

        _pageNumber--;
        await LoadAsync();
    }

    private async Task NextPage()
    {
        if (_pageNumber >= _result.TotalPages)
        {
            return;
        }

        _pageNumber++;
        await LoadAsync();
    }

    private int GetRowNumber(AppraisalListItemDto item)
    {
        var index = _result.Items.ToList().FindIndex(x => x.Id == item.Id);
        return ((_pageNumber - 1) * PageSize) + index + 1;
    }

    private string BuildResultsSubtitle()
    {
        if (_result.TotalItems == 0)
        {
            return "Tidak ada data yang cocok dengan filter pencarian.";
        }

        return $"Menampilkan {_result.Items.Count} data pada halaman ini dari {_result.TotalItems} total hasil pencarian.";
    }

    private string BuildDetailHref(string publicId)
        => AppRoutes.Inquiry.Detail(publicId);

    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DisplayDate(DateTime? value) => value.HasValue ? value.Value.ToString("dd MMM yyyy").ToUpperInvariant() : "-";

    private bool HasActiveFilters()
        => !string.IsNullOrWhiteSpace(_applicationNumber)
           || !string.IsNullOrWhiteSpace(_debtorName)
           || !string.IsNullOrWhiteSpace(_collateralSubtype)
           || _applicationDateFrom.HasValue
           || _applicationDateTo.HasValue;

    private static string ResolveApplicantDate(AppraisalListItemDto item)
    {
        var date = item.ApplicantType.Equals("Business", StringComparison.OrdinalIgnoreCase)
            ? item.BusinessEstablishedDate
            : item.DateOfBirth;

        return date.HasValue ? date.Value.ToString("dd MMM yyyy").ToUpperInvariant() : "-";
    }

}