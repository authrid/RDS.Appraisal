@page "/pencarian-data/{PublicId:guid}/history"
@page "/pencarian-data/history"
@attribute [Authorize]
@inject AppraisalSystem.Application.Interfaces.IAppraisalService AppraisalService
@inject NavigationManager NavigationManager

<PageTitle>Pencarian Data - History</PageTitle>

<BaseCard Title="History" Subtitle="Riwayat stage per aplikasi appraisal." Class="mx-auto w-full max-w-6xl">
    <LoadingSpinner Visible="_isLoading" Text="Memuat riwayat workflow..." />

    @if (!string.IsNullOrWhiteSpace(_feedbackMessage))
    {
        <BaseAlert Variant="@_feedbackVariant" Class="mb-3">@_feedbackMessage</BaseAlert>
    }

    <div class="space-y-5">
        <div class="rounded-2xl border border-slate-200 bg-[radial-gradient(circle_at_top_left,_rgba(59,130,246,0.12),_transparent_36%),linear-gradient(180deg,#f8fbff_0%,#f1f6fd_100%)] p-5">
            <p class="mb-1 text-[11px] font-extrabold uppercase tracking-[0.12em] text-blue-600">Workspace</p>
            <h3 class="mt-0 mb-2 text-xl font-extrabold text-slate-800">Monitoring history stage dalam satu tampilan</h3>
            <p class="mb-0 max-w-2xl text-sm leading-6 text-slate-600">Grid pertama menampilkan posisi stage saat ini. Grid kedua menampilkan perpindahan stage secara ringkas dari pencarian data maker sampai selesai.</p>
        </div>

        <BaseSectionPanel Eyebrow="Current Position" Title="Posisi Stage Saat Ini" Subtitle="Menampilkan posisi workflow saat ini, tanggal status, user, dan tujuan pengajuan.">
            <RightContent>
                <div class="flex flex-wrap gap-2">
                    <BaseButton Variant="secondary" Size="sm" OnClick="RefreshListAsync">
                        <span class="inline-flex items-center gap-2">
                            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                                <path d="M15.5 8A5.5 5.5 0 1 0 17 12"></path>
                                <path d="M16 4.5v4h-4"></path>
                            </svg>
                            <span>Refresh</span>
                        </span>
                    </BaseButton>
                </div>
            </RightContent>
            <ChildContent>
                <BaseTable TItem="CurrentStageRow" Items="_currentStageRows" ColSpan="4" EmptyText="Belum ada posisi stage untuk appraisal terpilih.">
                    <HeaderTemplate>
                        <BaseTableHeaderCell>Current Stage</BaseTableHeaderCell>
                        <BaseTableHeaderCell Class="w-44">Status Date</BaseTableHeaderCell>
                        <BaseTableHeaderCell Class="w-36">User</BaseTableHeaderCell>
                        <BaseTableHeaderCell Class="w-36">Next User</BaseTableHeaderCell>
                    </HeaderTemplate>
                    <RowTemplate Context="entry">
                        <BaseTableCell Tone="strong">
                            <span class="inline-flex items-center rounded-full border border-blue-200 bg-blue-50 px-2.5 py-1 text-[10px] font-semibold tracking-[0.04em] text-blue-700">
                                @Display(entry.Track)
                            </span>
                        </BaseTableCell>
                        <BaseTableCell Tone="soft">@FormatDate(entry.StatusDateUtc)</BaseTableCell>
                        <BaseTableCell Tone="default">@Display(entry.User)</BaseTableCell>
                        <BaseTableCell Tone="default">@Display(entry.NextUser)</BaseTableCell>
                    </RowTemplate>
                </BaseTable>
            </ChildContent>
        </BaseSectionPanel>

        <BaseSectionPanel Eyebrow="History Activity" Title="Detail History Stage" Subtitle="Menampilkan perpindahan stage secara ringkas tanpa deskripsi panjang.">
            <ChildContent>
                <BaseTable TItem="HistoryRow" Items="_historyRows.OrderByDescending(x => x.FromDateUtc).ToList()" ColSpan="5" EmptyText="Belum ada riwayat stage untuk appraisal terpilih.">
                    <HeaderTemplate>
                        <BaseTableHeaderCell Class="w-44">From Date</BaseTableHeaderCell>
                        <BaseTableHeaderCell Class="w-44">To Date</BaseTableHeaderCell>
                        <BaseTableHeaderCell>Track</BaseTableHeaderCell>
                        <BaseTableHeaderCell Class="w-36">User</BaseTableHeaderCell>
                        <BaseTableHeaderCell Class="w-36">Next User</BaseTableHeaderCell>
                    </HeaderTemplate>
                    <RowTemplate Context="entry">
                        <BaseTableCell Tone="soft">@FormatDate(entry.FromDateUtc)</BaseTableCell>
                        <BaseTableCell Tone="soft">@FormatDate(entry.ToDateUtc)</BaseTableCell>
                        <BaseTableCell Tone="strong">@Display(entry.Track)</BaseTableCell>
                        <BaseTableCell Tone="default">@Display(entry.User)</BaseTableCell>
                        <BaseTableCell Tone="default">@Display(entry.NextUser)</BaseTableCell>
                    </RowTemplate>
                </BaseTable>
            </ChildContent>
        </BaseSectionPanel>
    </div>
</BaseCard>

@code {
    [Parameter] public Guid? PublicId { get; set; }
    [SupplyParameterFromQuery(Name = "selectedPublicId")] public Guid? SelectedPublicId { get; set; }

    private string? _selectedPublicId;
    private AppraisalDetailDto? _detail;
    private List<CurrentStageRow> _currentStageRows = [];
    private List<HistoryRow> _historyRows = [];
    private bool _isLoading;
    private string _feedbackMessage = string.Empty;
    private string _feedbackVariant = "info";

    protected override Task OnInitializedAsync() => RefreshListCoreAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (!PublicId.HasValue && SelectedPublicId.HasValue)
        {
            var canonicalUrl = NavigationManager.ToAppPath(AppRoutes.PencarianData.HistoryByPublicId(SelectedPublicId.Value.ToString("D")));
            NavigationManager.NavigateTo(canonicalUrl, replace: true);
            return;
        }

        var effectivePublicId = PublicId ?? SelectedPublicId;
        var normalizedSelectedPublicId = effectivePublicId?.ToString("D");
        if (!string.Equals(normalizedSelectedPublicId, _selectedPublicId, StringComparison.OrdinalIgnoreCase))
        {
            _selectedPublicId = normalizedSelectedPublicId;
            await RefreshListCoreAsync();
        }
    }

    private Task RefreshListAsync(MouseEventArgs _) => RefreshListCoreAsync();

    private async Task RefreshListCoreAsync()
    {
        _isLoading = true;
        _feedbackMessage = string.Empty;

        try
        {
            if (string.IsNullOrWhiteSpace(_selectedPublicId))
            {
                _detail = null;
                _currentStageRows = [];
                _historyRows = [];
                _feedbackVariant = "warning";
                _feedbackMessage = "Pilih aplikasi terlebih dahulu dari halaman utama agar history bisa ditampilkan.";
                return;
            }

            _detail = await AppraisalService.GetByPublicIdAsync(_selectedPublicId);
            if (_detail is null)
            {
                _currentStageRows = [];
                _historyRows = [];
                _feedbackVariant = "warning";
                _feedbackMessage = "Data appraisal tidak ditemukan.";
                return;
            }

            var transitionEntries = ParseWorkflowHistory(_detail.WorkflowHistoryJson)
                .Where(IsStageTransition)
                .OrderBy(x => x.TimestampUtc)
                .ToList();

            _historyRows = BuildHistoryRows(_detail, transitionEntries);
            _currentStageRows = BuildCurrentStageRows(_detail, transitionEntries);
        }
        catch (Exception ex)
        {
            _feedbackVariant = "danger";
            _feedbackMessage = $"Gagal memuat history: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string BuildSelectedAppNo()
        => _detail is null ? "-" : (string.IsNullOrWhiteSpace(_detail.ApplicationNumber) ? $"APP-{_detail.Id:0000}" : _detail.ApplicationNumber);

    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static List<HistoryRow> BuildHistoryRows(AppraisalDetailDto detail, IReadOnlyList<WorkflowEntry> transitionEntries)
    {
        if (transitionEntries.Count == 0)
        {
            return [];
        }

        var rows = new List<HistoryRow>();

        var stageStatus = AppraisalStatus.Draft;
        var stageStartUtc = detail.CreatedAtUtc;

        foreach (var entry in transitionEntries)
        {
            var entryStatus = ResolveStageStatus(entry, stageStatus);
            rows.Add(new HistoryRow
            {
                FromDateUtc = stageStartUtc,
                ToDateUtc = entry.TimestampUtc,
                Track = AppraisalStageReference.GetDisplay(stageStatus),
                User = ResolveStageUser(stageStatus),
                NextUser = ResolveStageUser(entryStatus)
            });

            stageStatus = entryStatus;
            stageStartUtc = entry.TimestampUtc;
        }

        return rows;
    }

    private static List<CurrentStageRow> BuildCurrentStageRows(AppraisalDetailDto detail, IReadOnlyList<WorkflowEntry> transitionEntries)
    {
        var statusDateUtc = transitionEntries.LastOrDefault()?.TimestampUtc ?? detail.CreatedAtUtc;

        return
        [
            new CurrentStageRow
            {
                Track = AppraisalStageReference.GetDisplay(detail.Status),
                StatusDateUtc = statusDateUtc,
                User = ResolveStageUser(detail.Status),
                NextUser = ResolveCurrentNextUser(detail.Status)
            }
        ];
    }

    private static bool IsStageTransition(WorkflowEntry entry)
    {
        var action = (entry.Action ?? string.Empty).Trim().ToLowerInvariant();
        return action is "submitted" or "approved" or "rejected";
    }

    private static AppraisalStatus ResolveStageStatus(WorkflowEntry entry, AppraisalStatus currentStageStatus)
    {
        var action = (entry.Action ?? string.Empty).Trim().ToLowerInvariant();
        return action switch
        {
            "submitted" => AppraisalStatus.Submitted,
            "approved" => AppraisalStatus.Approved,
            "rejected" => AppraisalStatus.Rejected,
            _ => currentStageStatus
        };
    }

    private static string ResolveStageUser(AppraisalStatus status) => status switch
    {
        AppraisalStatus.Draft => "Appraiser",
        AppraisalStatus.Submitted => "Supervisor",
        AppraisalStatus.Approved or AppraisalStatus.Rejected => "Supervisor",
        _ => "-"
    };

    private static string ResolveCurrentNextUser(AppraisalStatus status) => status switch
    {
        AppraisalStatus.Draft => "Supervisor",
        AppraisalStatus.Submitted => "-",
        AppraisalStatus.Approved or AppraisalStatus.Rejected => "-",
        _ => "-"
    };

    private static string FormatDate(DateTime? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "-";

    private static List<WorkflowEntry> ParseWorkflowHistory(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return [];
        }

        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<WorkflowEntry>>(raw) ?? [];
        }
        catch
        {
            return [];
        }
    }

    private sealed class WorkflowEntry
    {
        public DateTime TimestampUtc { get; set; }
        public string Actor { get; set; } = string.Empty;
        public string Action { get; set; } = string.Empty;
        public string Note { get; set; } = string.Empty;
        public string StageCode { get; set; } = string.Empty;
        public string StageLabel { get; set; } = string.Empty;
    }

    private sealed class HistoryRow
    {
        public DateTime FromDateUtc { get; set; }
        public DateTime? ToDateUtc { get; set; }
        public string Track { get; set; } = string.Empty;
        public string User { get; set; } = string.Empty;
        public string NextUser { get; set; } = string.Empty;
    }

    private sealed class CurrentStageRow
    {
        public string Track { get; set; } = string.Empty;
        public DateTime StatusDateUtc { get; set; }
        public string User { get; set; } = string.Empty;
        public string NextUser { get; set; } = string.Empty;
    }
}