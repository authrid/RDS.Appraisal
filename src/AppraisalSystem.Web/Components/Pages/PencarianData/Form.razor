    private Task OnProvinceChanged(string? value)
    {
        var next = value ?? string.Empty;
        var provinceChanged = !string.Equals(_model.Province, next, StringComparison.OrdinalIgnoreCase);
        _model.Province = next;

        if (provinceChanged)
        {
            _model.City = string.Empty;
            _model.District = string.Empty;
            _model.Subdistrict = string.Empty;
