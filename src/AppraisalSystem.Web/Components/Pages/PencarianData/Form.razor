@using AppraisalSystem.Application.Features.ChatUI
@using AppraisalSystem.Web.Components.Features.ChatUI
@using AppraisalSystem.Web.Services
@using System.Text.Json
@using System.Text.Json.Serialization
@attribute [Authorize(Roles = AppRoles.AppraiserOrSupervisorOrAdmin)]
@inject AppraisalSystem.Application.Interfaces.IAppraisalService AppraisalService
@inject AppraisalSystem.Application.Interfaces.IReferenceDataService ReferenceService
@inject SavedSessionsService SavedSessions
@inject NavigationManager NavigationManager

@page "/appraisals/create"
@page "/pencarian-data/create"
@page "/pencarian-data/{PublicId:guid}/edit"

<PageTitle>Form Appraisal</PageTitle>

<BaseCard Title="Form Appraisal" Subtitle="Lengkapi data debitur dan data aplikasi secara ringkas." Class="w-full">
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <BaseValidationSummary />

        <div class="space-y-5">
            <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="border-b border-slate-200 pb-3">
                    <p class="mb-0 text-[11px] font-extrabold uppercase tracking-[0.12em] text-blue-600">Data Aplikasi</p>
                    <p class="mt-1 mb-0 text-sm text-slate-500">Isi detail utama aplikasi agar proses appraisal lebih terstruktur.</p>
                </div>

                <div class="mt-4 grid grid-cols-1 gap-4 xl:grid-cols-2">
                    <div class="rounded-xl border border-slate-200 bg-slate-50/70 p-3">
                        @* <p class="mb-3 text-xs font-semibold uppercase tracking-[0.08em] text-slate-500">Informasi Utama</p> *@
                        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                            <BaseTextField Id="applicationNumber" Label="No. Aplikasi" Class="md:col-span-2" @bind-Value="_model.ApplicationNumber" Placeholder="Auto Generated" />

                            <BaseSelectField TValue="CustomerSegment" Id="segment" Label="Segment" @bind-Value="_model.Segment">
                                @foreach (var segment in Enum.GetValues<CustomerSegment>().Where(x => x != CustomerSegment.Unknown))
                                {
                                    <option value="@segment">@segment</option>
                                }
                            </BaseSelectField>

                            <BaseTextField Id="makerId" Label="Maker" @bind-Value="_model.MakerId" />
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-200 bg-slate-50/70 p-3">
                        @* <p class="mb-3 text-xs font-semibold uppercase tracking-[0.08em] text-slate-500">Konteks Aplikasi</p> *@
                        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                            <BaseSearchListModalField Id="branchCode"
                                                      Label="Cabang"
                                                      Class="md:col-span-2"
                                                      Value="@_selectedBranchName"
                                                      ValueChanged="OnBranchNameChanged"
                                                      Options="@_branchDisplayOptions"
                                                      Placeholder="Pilih Cabang"
                                                      ModalTitle="Pilih Cabang"
                                                      ModalSubtitle="Pilih cabang dari daftar yang tersedia." />

                            <BaseFormInput Id="applicationDateUtc" Label="Tanggal Aplikasi">
                                <InputDate TValue="DateTime?"
                                           id="applicationDateUtc"
                                           @bind-Value="_model.ApplicationDateUtc"
                                           class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm text-slate-700 outline-none transition focus:border-blue-400 focus:ring-4 focus:ring-blue-100" />
                            </BaseFormInput>
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 pb-3">
                    <div>
                        <p class="mb-0 text-[11px] font-extrabold uppercase tracking-[0.12em] text-blue-600">Data Pengajuan</p>
                        <p class="mt-1 mb-0 text-sm text-slate-500">Pilih jenis nasabah untuk menyesuaikan input identitas.</p>
                    </div>

                    <InputRadioGroup @bind-Value="_model.ApplicantType" Name="applicantType">
                        <div class="flex flex-wrap gap-2 text-sm text-slate-700">
                            <label class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                                <InputRadio Value="@ApplicantType.Business" />
                                <span>@ApplicantType.Business.GetLabel()</span>
                            </label>

                            <label class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                                <InputRadio Value="@ApplicantType.Individual" />
                                <span>@ApplicantType.Individual.GetLabel()</span>
                            </label>
                        </div>
                    </InputRadioGroup>
                </div>

                <div class="mt-4 grid grid-cols-1 gap-4 xl:grid-cols-2">
                    <div class="rounded-xl border border-slate-200 bg-slate-50/70 p-3">
                        @* <p class="mb-3 text-xs font-semibold uppercase tracking-[0.08em] text-slate-500">Informasi Tambahan</p> *@

                        @if (_model.ApplicantType == ApplicantType.Business)
                        {
                            <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                                <BaseSelectField TValue="string" Id="legalEntity" Label="Badan Hukum" @bind-Value="_model.LegalEntity">
                                    <option value="">Pilih Badan Hukum</option>
                                    @foreach (var legalEntity in _legalEntityOptions)
                                    {
                                        <option value="@legalEntity.Code">@legalEntity.Label</option>
                                    }
                                </BaseSelectField>

                                <BaseTextField Id="debtorName" Label="Nama Perusahaan" @bind-Value="_model.DebtorName" />
                                <BaseTextField Id="deedNumber" Label="No Akta" @bind-Value="_model.DeedNumber" />
                                <BaseTextField Id="identityNumber" Label="No NPWP" @bind-Value="_model.IdentityNumber" />

                                <BaseFormInput Id="businessEstablishedDate" Label="Tanggal Pendirian Usaha" Class="md:col-span-2">
                                    <InputDate TValue="DateTime?"
                                               id="businessEstablishedDate"
                                               @bind-Value="_model.BusinessEstablishedDate"
                                               class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm text-slate-700 outline-none transition focus:border-blue-400 focus:ring-4 focus:ring-blue-100" />
                                </BaseFormInput>

                                <BaseTextField Id="phoneNumber" Label="No Telepon" @bind-Value="_model.PhoneNumber" />
                                <BaseTextField Id="mobileNumber1" Label="Handphone 1" @bind-Value="_model.MobileNumber1" />
                                <BaseTextField Id="mobileNumber2" Label="Handphone 2" @bind-Value="_model.MobileNumber2" />
                                <BaseTextField Id="email" Label="Email" @bind-Value="_model.Email" />
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                                <BaseTextField Id="debtorName" Label="Nama Lengkap" Class="md:col-span-2" @bind-Value="_model.DebtorName" />
                                <BaseTextField Id="identityNumber" Label="No KTP" @bind-Value="_model.IdentityNumber" />
                                <BaseTextField Id="birthPlace" Label="Tempat Lahir" @bind-Value="_model.BirthPlace" />

                                <BaseFormInput Id="dateOfBirth" Label="Tanggal Lahir">
                                    <InputDate TValue="DateTime?"
                                               id="dateOfBirth"
                                               @bind-Value="_model.DateOfBirth"
                                               class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm text-slate-700 outline-none transition focus:border-blue-400 focus:ring-4 focus:ring-blue-100" />
                                </BaseFormInput>

                                <BaseSelectField TValue="string" Id="gender" Label="Jenis Kelamin" @bind-Value="_model.Gender">
                                    <option value="">Pilih Jenis Kelamin</option>
                                    @foreach (var gender in _genderOptions)
                                    {
                                        <option value="@gender.Code">@gender.Label</option>
                                    }
                                </BaseSelectField>

                                <BaseSelectField TValue="string" Id="maritalStatus" Label="Status Pernikahan" @bind-Value="_model.MaritalStatus">
                                    <option value="">Pilih Status</option>
                                    @foreach (var maritalStatus in _maritalStatusOptions)
                                    {
                                        <option value="@maritalStatus.Code">@maritalStatus.Label</option>
                                    }
                                </BaseSelectField>

                                <BaseTextField Id="phoneNumber" Label="No Telepon" @bind-Value="_model.PhoneNumber" />
                                <BaseTextField Id="mobileNumber1" Label="Handphone 1" @bind-Value="_model.MobileNumber1" />
                                <BaseTextField Id="mobileNumber2" Label="Handphone 2" @bind-Value="_model.MobileNumber2" />
                                <BaseTextField Id="email" Label="Email" @bind-Value="_model.Email" />
                            </div>
                        }
                    </div>

                    <div class="rounded-xl border border-slate-200 bg-slate-50/70 p-3">
                        @* <p class="mb-3 text-xs font-semibold uppercase tracking-[0.08em] text-slate-500">Informasi Tambahan</p> *@

                        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                            <BaseSearchListModalField Id="collateralSubtype"
                                                      Label="Jenis Jaminan"
                                                      Class="md:col-span-2"
                                                      Value="@_model.CollateralSubtype"
                                                      ValueChanged="OnCollateralSubtypeChanged"
                                                      Options="@_collateralSubtypeDisplayOptions"
                                                      Placeholder="Pilih Jenis Jaminan"
                                                      ModalTitle="Pilih Jenis Jaminan"
                                                      ModalSubtitle="Pilih jenis jaminan/agunan sesuai kategori aset." />

                            <BaseTextField Id="address" Label="Alamat" Class="md:col-span-2" @bind-Value="_model.AddressLine1" />

                            <BaseTextField Id="rt" Label="RT" @bind-Value="_model.Rt" />
                            <BaseTextField Id="rw" Label="RW" @bind-Value="_model.Rw" />
                            <BaseTextField Id="postalCode" Label="Kode Pos" @bind-Value="_model.PostalCode" />

                            <BaseSearchListModalField Id="city"
                                                      Label="Kota/Kabupaten"
                                                      Value="@_model.City"
                                                      ValueChanged="OnCityChanged"
                                                      Options="@_cityDisplayOptions"
                                                      Placeholder="Pilih Kota/Kabupaten"
                                                      ModalTitle="Pilih Kota/Kabupaten"
                                                      ModalSubtitle="Daftar kota mengikuti provinsi yang dipilih." />

                            <BaseSearchListModalField Id="district"
                                                      Label="Kecamatan"
                                                      Value="@_model.District"
                                                      ValueChanged="OnDistrictChanged"
                                                      Options="@_districtDisplayOptions"
                                                      Placeholder="Pilih Kecamatan"
                                                      ModalTitle="Pilih Kecamatan"
                                                      ModalSubtitle="Daftar kecamatan mengikuti kota yang dipilih." />

                            <BaseSearchListModalField Id="subdistrict"
                                                      Label="Kelurahan"
                                                      Value="@_model.Subdistrict"
                                                      ValueChanged="OnSubdistrictChanged"
                                                      Options="@_subdistrictDisplayOptions"
                                                      Placeholder="Pilih Kelurahan"
                                                      ModalTitle="Pilih Kelurahan"
                                                      ModalSubtitle="Daftar kelurahan mengikuti kecamatan yang dipilih." />

                            <BaseSearchListModalField Id="province"
                                                      Label="Provinsi"
                                                      Value="@_model.Province"
                                                      ValueChanged="OnProvinceChanged"
                                                      Options="@_provinceDisplayOptions"
                                                      Placeholder="Pilih Provinsi"
                                                      ModalTitle="Pilih Provinsi"
                                                      ModalSubtitle="Cari provinsi dari daftar wilayah Indonesia." />

                            <BaseSearchListModalField Id="country"
                                                      Label="Negara"
                                                      Value="@_model.Country"
                                                      ValueChanged="OnCountryChanged"
                                                      Options="@_countryDisplayOptions"
                                                      Placeholder="Pilih Negara"
                                                      ModalTitle="Pilih Negara"
                                                      ModalSubtitle="Cari negara dari daftar yang tersedia." />
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="mb-3 flex items-center justify-between gap-3 border-b border-slate-200 pb-3">
                    <div>
                        <p class="mb-0 text-[11px] font-extrabold uppercase tracking-[0.12em] text-blue-600">Chat AI</p>
                        <h3 class="mt-1 mb-0 text-base font-bold text-slate-700">Data pembanding untuk pendekatan pasar</h3>
                    </div>
                </div>
                <ChatContainer />
                <SavedListTable DbListings="@_dbListings" DbSessionJson="@_dbSessionJson" />
            </section>
        </div>

        <div class="mt-5 flex flex-wrap justify-end gap-2 border-t border-slate-200 pt-4">
            <BaseButton Variant="secondary" Size="lg" OnClick="BackAsync">
                <span class="inline-flex items-center gap-2">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M8 5l-5 5 5 5"></path>
                        <path d="M4 10h13"></path>
                    </svg>
                    <span>Back</span>
                </span>
            </BaseButton>
            <BaseButton ButtonType="submit" Variant="brand" Size="lg">
                <span class="inline-flex items-center gap-2">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M4 10.5V5.5A1.5 1.5 0 0 1 5.5 4h7L16 7.5v8a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 4 15.5z"></path>
                        <path d="M7 4.5v4h5v-4"></path>
                        <path d="M7.5 13h5"></path>
                    </svg>
                    <span>Save</span>
                </span>
            </BaseButton>
        </div>
    </EditForm>
</BaseCard>

@code {
    [Parameter] public Guid? PublicId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }
    private const string ComparableMarker = "[[COMPARABLES]]";

    private AppraisalUpsertDto _model = new();
    private bool _isEdit;
    private bool _canCreateNew = true;
    private bool _referenceLoaded;
    private List<ComparableInput> _comparables = [new()];
    private List<PropertyListing>? _dbListings;
    private string? _dbSessionJson;
    private string? _selectedBranchName;

    // Reference data terpusat (JSON hari ini via IReferenceDataService; DB nanti tanpa mengubah komponen).
    private IReadOnlyList<ReferenceItemDto> _genderOptions = Array.Empty<ReferenceItemDto>();
    private IReadOnlyList<ReferenceItemDto> _maritalStatusOptions = Array.Empty<ReferenceItemDto>();
    private IReadOnlyList<ReferenceItemDto> _legalEntityOptions = Array.Empty<ReferenceItemDto>();
    private IReadOnlyList<ReferenceItemDto> _countryOptions = Array.Empty<ReferenceItemDto>();
    private IReadOnlyList<ReferenceItemDto> _collateralSubtypeOptions = Array.Empty<ReferenceItemDto>();
    private IReadOnlyList<ReferenceItemDto> _provinceOptions = Array.Empty<ReferenceItemDto>();
    private IReadOnlyList<ReferenceItemDto> _cityOptions = Array.Empty<ReferenceItemDto>();
    private IReadOnlyList<ReferenceItemDto> _districtOptions = Array.Empty<ReferenceItemDto>();
    private IReadOnlyList<ReferenceItemDto> _subdistrictOptions = Array.Empty<ReferenceItemDto>();
    private IReadOnlyList<ReferenceItemDto> _branchOptions = Array.Empty<ReferenceItemDto>();

    // BaseSearchListModalField menerima string[] Options; kita render Display (kode - label untuk cabang, label untuk lainnya).
    private string[] _collateralSubtypeDisplayOptions = Array.Empty<string>();
    private string[] _provinceDisplayOptions = Array.Empty<string>();
    private string[] _cityDisplayOptions = Array.Empty<string>();
    private string[] _districtDisplayOptions = Array.Empty<string>();
    private string[] _subdistrictDisplayOptions = Array.Empty<string>();
    private string[] _countryDisplayOptions = Array.Empty<string>();
    private string[] _branchDisplayOptions = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        await EnsureReferenceDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reference data hanya di-load sekali per instance komponen.
        await EnsureReferenceDataAsync();

        _isEdit = PublicId.HasValue;

        var authState = await (AuthenticationStateTask ?? Task.FromResult(new AuthenticationState(new ClaimsPrincipal())));
        var user = authState.User;
        var isSupervisor = user.IsInRole(AppRoles.Supervisor) || user.IsInRole(AppRoles.Checker);
        var isAdmin = user.IsInRole(AppRoles.Admin);
        var isAppraiser = user.IsInRole(AppRoles.Appraiser);

        _canCreateNew = isAdmin || isAppraiser;

        if (!_isEdit)
        {
            if (!_canCreateNew)
            {
                NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.Account.AccessDenied));
                return;
            }

            _model = CreateDefaultModel();
            _comparables = [new()];
            return;
        }

        var existing = await AppraisalService.GetByPublicIdAsync(PublicId!.Value.ToString("D"));
        if (existing is null)
        {
            NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Main));
            return;
        }

        // Approved hanya boleh dibuka lewat Pengkinian Data (reopen ke Draft).
        if (existing.Status == AppraisalStatus.Approved)
        {
            NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Detail(existing.PublicId)));
            return;
        }

        var canEditExisting = isAdmin
            || isSupervisor
            || (isAppraiser && existing.Status != AppraisalStatus.Submitted);

        if (!canEditExisting)
        {
            NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Detail(existing.PublicId)));
            return;
        }

        var (plainNotes, comparables) = ParseComparableSection(existing.Notes);

        _model = new AppraisalUpsertDto
        {
            Id = existing.Id,
            ApplicationNumber = existing.ApplicationNumber,
            Segment = existing.Segment,
            MakerId = existing.MakerId,
            BranchCode = existing.BranchCode,
            ApplicationDateUtc = existing.ApplicationDateUtc,
            ApplicantType = existing.ApplicantType,
            DeedNumber = existing.DeedNumber,
            DateOfBirth = existing.DateOfBirth,
            BusinessEstablishedDate = existing.BusinessEstablishedDate,
            LegalEntity = existing.LegalEntity,
            BirthPlace = existing.BirthPlace,
            Gender = existing.Gender,
            MaritalStatus = existing.MaritalStatus,
            AddressLine1 = existing.AddressLine1,
            AddressLine2 = existing.AddressLine2,
            AddressLine3 = existing.AddressLine3,
            Rt = existing.Rt,
            Rw = existing.Rw,
            PostalCode = existing.PostalCode,
            Subdistrict = existing.Subdistrict,
            District = existing.District,
            City = existing.City,
            Province = existing.Province,
            Country = existing.Country,
            PhoneNumber = existing.PhoneNumber,
            MobileNumber1 = existing.MobileNumber1,
            MobileNumber2 = existing.MobileNumber2,
            Email = existing.Email,
            DebtorName = existing.DebtorName,
            IdentityNumber = existing.IdentityNumber,
            CollateralType = existing.CollateralType,
            CollateralSubtype = existing.CollateralSubtype,
            MarketValue = existing.MarketValue,
            LiquidationValue = existing.LiquidationValue,
            Notes = plainNotes
        };

        // Tampilkan cabang sebagai "code - name" tapi simpan tetap sebagai code.
        var existingBranch = FindBranchBySelection(existing.BranchCode);
        _selectedBranchName = existingBranch is null
            ? existing.BranchCode
            : existingBranch.Display;
        _model.BranchCode = existingBranch?.Code ?? existing.BranchCode;


        _comparables = comparables.Count > 0 ? comparables : [new()];

        // Sesuaikan opsi cascading geo dengan nilai yang sudah tersimpan.
        RefreshGeoDisplayOptions();

        // Load saved property listings & session context from DB
        if (existing.Id > 0)
        {
            _dbListings = await AppraisalService.GetListingsAsync(existing.Id);
            _dbSessionJson = existing.SavedSessionJson;

            if (!string.IsNullOrWhiteSpace(existing.SavedSessionJson))
                SavedSessions.LoadSessionsFromJson(existing.SavedSessionJson);
            else if (_dbListings.Count > 0)
                SavedSessions.LoadFromRepository(_dbListings);
        }
        else
        {
            _dbListings = null;
            _dbSessionJson = null;
        }

        if (string.IsNullOrWhiteSpace(_model.ApplicationNumber))
        {
            _model.ApplicationNumber = GenerateApplicationNumber(_model.Segment);
        }
    }

    private async Task SaveAsync()
    {
        _model.Notes = BuildNotesWithComparableSection(_model.Notes, _comparables);

        // Serialize session context ke JSON
        var sessionsList = SavedSessions.Sessions;
        var hasSessionData = sessionsList.Count > 0
            && (sessionsList.Sum(s => s.Listings.Count) > 0
                || sessionsList.Any(s => s.Address is not null)
                || sessionsList.Any(s => s.Certificate is not null));
        if (hasSessionData)
        {
            _model.SavedSessionJson = System.Text.Json.JsonSerializer.Serialize(
                sessionsList,
                new System.Text.Json.JsonSerializerOptions
                {
                    PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase,
                    WriteIndented = false
                });
        }
        else
        {
            _model.SavedSessionJson = string.Empty;
        }

        // Ekstrak address & certificate untuk disimpan ke tabel OcrResults
        // Prioritas: dari LastOcr (langsung dari OCR) → fallback dari session
        var ocrAddress = SavedSessions.LastOcrAddress
            ?? SavedSessions.Sessions.Select(s => s.Address).FirstOrDefault(a => a is not null);
        var ocrCert = SavedSessions.LastOcrCertificate
            ?? SavedSessions.Sessions.Select(s => s.Certificate).FirstOrDefault(c => c is not null);

        if (_isEdit)
        {
            await AppraisalService.UpdateAsync(_model);

            // Save property listings to DB
            var allListings = SavedSessions.Sessions.SelectMany(s => s.Listings).ToList();
            if (_model.Id.HasValue)
            {
                await AppraisalService.SaveListingsAsync(_model.Id.Value, allListings);
                if (ocrAddress is not null || ocrCert is not null)
                    await AppraisalService.SaveOcrResultAsync(_model.Id.Value, ocrAddress, ocrCert);
            }

            // Hapus data localStorage karena sudah tersimpan di database
            await SavedSessions.ClearAllAsync();

            NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Detail(PublicId!.Value.ToString("D"))), forceLoad: true);
            return;
        }
        else
        {
            if (!_canCreateNew)
            {
                NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.Account.AccessDenied));
                return;
            }

            var authState = await (AuthenticationStateTask ?? Task.FromResult(new AuthenticationState(new ClaimsPrincipal())));
            var username = authState.User.Identity?.Name ?? "system";
            var newId = await AppraisalService.CreateAsync(_model, username);

            // Save property listings to DB
            var allListings = SavedSessions.Sessions.SelectMany(s => s.Listings).ToList();
            if (allListings.Count > 0)
                await AppraisalService.SaveListingsAsync(newId, allListings);

            // Save OCR result
            if (ocrAddress is not null || ocrCert is not null)
                await AppraisalService.SaveOcrResultAsync(newId, ocrAddress, ocrCert);

            // Hapus data localStorage karena sudah tersimpan di database
            await SavedSessions.ClearAllAsync();

            var created = await AppraisalService.GetByIdAsync(newId);
            if (created is null)
            {
                NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Main));
                return;
            }

            NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Detail(created.PublicId)), forceLoad: true);
            return;
        }
    }

    private void Back()
    {
        if (_isEdit && PublicId.HasValue)
        {
            NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Detail(PublicId.Value.ToString("D"))));
            return;
        }

        NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Main));
    }

    private Task AddComparableAsync(MouseEventArgs _)
    {
        _comparables.Add(new ComparableInput());
        return Task.CompletedTask;
    }

    private Task RemoveComparableAsync(MouseEventArgs _, int index)
    {
        if (index < 0 || index >= _comparables.Count)
        {
            return Task.CompletedTask;
        }

        _comparables.RemoveAt(index);

        if (_comparables.Count == 0)
        {
            _comparables.Add(new ComparableInput());
        }

        return Task.CompletedTask;
    }

    private static string BuildNotesWithComparableSection(string notes, IReadOnlyList<ComparableInput> comparables)
    {
        var cleanNotes = (notes ?? string.Empty).Trim();

        var validComparables = comparables
            .Where(IsComparableFilled)
            .Select(x => new ComparableInput
            {
                Source = x.Source.Trim(),
                Location = x.Location.Trim(),
                Specification = x.Specification.Trim(),
                LandArea = x.LandArea,
                BuildingArea = x.BuildingArea,
                OfferPrice = x.OfferPrice,
                AdjustmentPercent = x.AdjustmentPercent,
                IndicatedValue = x.IndicatedValue,
                Remarks = x.Remarks.Trim()
            })
            .ToList();

        if (validComparables.Count == 0)
        {
            return cleanNotes;
        }

        var payload = System.Text.Json.JsonSerializer.Serialize(validComparables);
        return string.IsNullOrWhiteSpace(cleanNotes)
            ? $"{ComparableMarker}{payload}"
            : $"{cleanNotes}\n\n{ComparableMarker}{payload}";
    }

    private static (string Notes, List<ComparableInput> Comparables) ParseComparableSection(string? rawNotes)
    {
        var value = rawNotes ?? string.Empty;
        var markerIndex = value.IndexOf(ComparableMarker, StringComparison.Ordinal);

        if (markerIndex < 0)
        {
            return (value, []);
        }

        var plainNotes = value[..markerIndex].TrimEnd();
        var json = value[(markerIndex + ComparableMarker.Length)..].Trim();

        if (string.IsNullOrWhiteSpace(json))
        {
            return (plainNotes, []);
        }

        try
        {
            var comparables = System.Text.Json.JsonSerializer.Deserialize<List<ComparableInput>>(json) ?? [];
            return (plainNotes, comparables);
        }
        catch
        {
            return (value, []);
        }
    }

    private static bool IsComparableFilled(ComparableInput input)
    {
        return !string.IsNullOrWhiteSpace(input.Source)
            || !string.IsNullOrWhiteSpace(input.Location)
            || !string.IsNullOrWhiteSpace(input.Specification)
            || input.LandArea.HasValue
            || input.BuildingArea.HasValue
            || input.OfferPrice.HasValue
            || input.AdjustmentPercent.HasValue
            || input.IndicatedValue.HasValue
            || !string.IsNullOrWhiteSpace(input.Remarks);
    }

    private sealed class ComparableInput
    {
        public string Source { get; set; } = string.Empty;
        public string Location { get; set; } = string.Empty;
        public string Specification { get; set; } = string.Empty;
        public decimal? LandArea { get; set; }
        public decimal? BuildingArea { get; set; }
        public decimal? OfferPrice { get; set; }
        public decimal? AdjustmentPercent { get; set; }
        public decimal? IndicatedValue { get; set; }
        public string Remarks { get; set; } = string.Empty;
    }

