    private Task OnBranchNameChanged(string? value)
    {
        _selectedBranchName = value;
        var selectedBranch = FindBranchBySelection(value);
        _model.BranchCode = selectedBranch?.Code ?? string.Empty;
        return Task.CompletedTask;
    }

    private ReferenceItemDto? FindBranchBySelection(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || _branchOptions.Count == 0)
        {
            return null;
        }

        var key = value.Trim();

        var byDisplay = _branchOptions.FirstOrDefault(b =>
            string.Equals(b.Display, key, StringComparison.OrdinalIgnoreCase));

        if (byDisplay is not null)
        {
            return byDisplay;
        }

        var byCode = _branchOptions.FirstOrDefault(b =>
            string.Equals(b.Code, key, StringComparison.OrdinalIgnoreCase));

        if (byCode is not null)
        {
            return byCode;
        }

        return _branchOptions.FirstOrDefault(b =>
            string.Equals(b.Label, key, StringComparison.OrdinalIgnoreCase));
    }

    private async Task EnsureReferenceDataAsync()
    {
        if (_referenceLoaded)
        {
            return;
        }

        try
        {
            var collateralTask = ReferenceService.GetCollateralSubtypesAsync();
            var provinceTask = ReferenceService.GetProvincesAsync();
            var cityTask = ReferenceService.GetCitiesAsync();
            var districtTask = ReferenceService.GetDistrictsAsync();
            var subdistrictTask = ReferenceService.GetSubdistrictsAsync();
            var countryTask = ReferenceService.GetCountriesAsync();
            var maritalTask = ReferenceService.GetMaritalStatusesAsync();
            var genderTask = ReferenceService.GetGendersAsync();
            var legalEntityTask = ReferenceService.GetLegalEntitiesAsync();
            var branchTask = ReferenceService.GetBranchesAsync();

            await Task.WhenAll(
                collateralTask, provinceTask, cityTask, districtTask, subdistrictTask,
                countryTask, maritalTask, genderTask, legalEntityTask, branchTask);

            _collateralSubtypeOptions = collateralTask.Result;
            _provinceOptions = provinceTask.Result;
            _cityOptions = cityTask.Result;
            _districtOptions = districtTask.Result;
            _subdistrictOptions = subdistrictTask.Result;
            _countryOptions = countryTask.Result;
            _maritalStatusOptions = maritalTask.Result;
            _genderOptions = genderTask.Result;
            _legalEntityOptions = legalEntityTask.Result;
            _branchOptions = branchTask.Result;

            _collateralSubtypeDisplayOptions = _collateralSubtypeOptions.Select(x => x.Label).ToArray();
            _provinceDisplayOptions = _provinceOptions.Select(x => x.Label).ToArray();
            _countryDisplayOptions = _countryOptions.Select(x => x.Label).ToArray();
            _branchDisplayOptions = _branchOptions.Select(x => x.Display).ToArray();

            RefreshGeoDisplayOptions();
        }
        finally
        {
            _referenceLoaded = true;
        }
    }

    private void RefreshGeoDisplayOptions()
    {
        // Cascading: kalau parent kosong, tampilkan semua sample agar edit data lama tetap searchable.
        // Kalau parent terisi, filter anak berdasarkan ParentCode.
        _cityDisplayOptions = FilterByParent(_cityOptions, _model.Province)
            .Select(x => x.Label)
            .ToArray();

        _districtDisplayOptions = FilterByParent(_districtOptions, _model.City)
            .Select(x => x.Label)
            .ToArray();

        _subdistrictDisplayOptions = FilterByParent(_subdistrictOptions, _model.District)
            .Select(x => x.Label)
            .ToArray();
    }

    private static IEnumerable<ReferenceItemDto> FilterByParent(IReadOnlyList<ReferenceItemDto> items, string? parentCode)
    {
        if (string.IsNullOrWhiteSpace(parentCode))
        {
            return items;
        }

        var parent = parentCode.Trim();
        var filtered = items.Where(x => string.Equals(x.ParentCode, parent, StringComparison.OrdinalIgnoreCase)).ToList();

        // Fallback: jika parent belum punya anak di sample JSON, tampilkan semua agar UI tidak kosong total.
        return filtered.Count > 0 ? filtered : items;
    }

    private static AppraisalUpsertDto CreateDefaultModel()
    {
        var segment = CustomerSegment.Consumer;

        return new AppraisalUpsertDto
        {
            Segment = segment,
            ApplicantType = ApplicantType.Individual,
            ApplicationDateUtc = DateTime.Today,
            ApplicationNumber = GenerateApplicationNumber(segment)
        };
    }

    private static string GenerateApplicationNumber(CustomerSegment segment)
    {
        var prefix = segment switch
        {
            CustomerSegment.Consumer => "CON",
            CustomerSegment.Commercial => "COM",
            CustomerSegment.SME => "SME",
            CustomerSegment.Corporate => "COR",
            _ => "APP"
        };

        return $"{prefix}.{DateTime.Now:yyyyMMdd}.{Random.Shared.Next(1, 999):000}";
    }
