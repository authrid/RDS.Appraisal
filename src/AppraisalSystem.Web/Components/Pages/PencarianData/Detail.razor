<ConfirmationDialog Open="_showApproveDialog"
                    Title="Approve Appraisal"
                    Message="Lanjutkan proses approve appraisal ini?"
                    ConfirmText="Approve"
                    OnConfirm="ApproveAsync"
                    OnCancel="CloseDialogs" />

<ConfirmationDialog Open="_showRejectDialog"
                    Title="Reject Appraisal"
                    Message="Lanjutkan proses reject appraisal ini?"
                    ConfirmText="Reject"
                    OnConfirm="RejectAsync"
                    OnCancel="CloseDialogs" />

@code {
    [Parameter] public Guid PublicId { get; set; }
    [SupplyParameterFromQuery(Name = "readonly")] public bool ReadOnlyQueryMode { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool _isLoading = true;
    private AppraisalDetailDto? _detail;
    private string _supervisorNote = string.Empty;
    private bool _showApproveDialog;
    private bool _showRejectDialog;
    private const string ComparableMarker = "[[COMPARABLES]]";
    private string _plainNotes = string.Empty;
    private List<ComparableDetail> _comparables = [];
    private List<PropertyListing> _listings = [];
    private AddressInfo? _sessionAddress;
    private CertificatePayload? _sessionCert;
    private bool _isSupervisorOrAdmin;
    private bool _isAppraiserOrAdmin;

    private bool IsInquiryRoute => NavigationManager.ToBaseRelativePath(NavigationManager.Uri).StartsWith("inquiry/", StringComparison.OrdinalIgnoreCase);

    private bool ReadOnlyMode => IsInquiryRoute || ReadOnlyQueryMode;

    private bool CanEditCurrentAppraisal => !ReadOnlyMode
        && _detail is not null
        && (_detail.Status == AppraisalStatus.Submitted ? _isSupervisorOrAdmin : _isAppraiserOrAdmin);

    private bool CanSubmitCurrentAppraisal => !ReadOnlyMode
        && _detail is not null
        && _detail.Status == AppraisalStatus.Draft
        && _isAppraiserOrAdmin;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;

        var authState = await (AuthenticationStateTask ?? Task.FromResult(new AuthenticationState(new System.Security.Claims.ClaimsPrincipal())));
        var user = authState.User;
        _isSupervisorOrAdmin = user.IsInRole("Supervisor") || user.IsInRole("Admin");
        _isAppraiserOrAdmin = user.IsInRole("Appraiser") || user.IsInRole("Admin");

        _detail = await AppraisalService.GetByPublicIdAsync(PublicId.ToString("D"));
        if (_detail is not null)
        {
            var parsed = ParseComparableSection(_detail.Notes);
            _plainNotes = parsed.Notes;
            _comparables = parsed.Comparables;
            _listings = await AppraisalService.GetListingsAsync(_detail.Id);

            // Load OCR result dari tabel terpisah (prioritas utama)
            var (ocrAddr, ocrCert) = await AppraisalService.GetOcrResultAsync(_detail.Id);
            if (ocrAddr is not null || ocrCert is not null)
            {
                _sessionAddress = ocrAddr;
                _sessionCert = ocrCert;
            }
            else
            {
                // Fallback: parse dari SavedSessionJson (data lama)
                if (!string.IsNullOrWhiteSpace(_detail.SavedSessionJson) && _detail.SavedSessionJson != "[]")
                {
                    try
                    {
                        var sessions = System.Text.Json.JsonSerializer.Deserialize<List<SavedSession>>(
                            _detail.SavedSessionJson,
                            new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
                        if (sessions is { Count: > 0 })
                        {
                            var first = sessions[0];
                            _sessionAddress = first.Address;
                            _sessionCert = first.Certificate;
                        }
                    }
                    catch { /* ignore parse errors */ }
                }
            }
        }
        _isLoading = false;

        if (_detail is null)
        {
            NavigationManager.NavigateTo(NavigationManager.ToAppPath(IsInquiryRoute ? AppRoutes.Inquiry.Main : AppRoutes.PencarianData.Main));
        }
    }

    private async Task SubmitAsync(MouseEventArgs _)
    {
        if (!CanSubmitCurrentAppraisal)
        {
            return;
        }

        await AppraisalService.SubmitAsync(_detail!.Id, ResolveActorName());
        NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Main));
    }

    private void OpenApproveDialog() => _showApproveDialog = true;

    private void OpenRejectDialog() => _showRejectDialog = true;

    private Task OpenApproveDialogAsync(MouseEventArgs _)
    {
        OpenApproveDialog();
        return Task.CompletedTask;
    }

    private Task OpenRejectDialogAsync(MouseEventArgs _)
    {
        OpenRejectDialog();
        return Task.CompletedTask;
    }

    private Task CloseDialogs()
    {
        _showApproveDialog = false;
        _showRejectDialog = false;
        return Task.CompletedTask;
    }

    private async Task ApproveAsync()
    {
        await AppraisalService.ApproveAsync(_detail!.Id, _supervisorNote, ResolveActorName());
        await CloseDialogs();
        NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Detail(PublicId.ToString("D"))), forceLoad: true);
    }

    private async Task RejectAsync()
    {
        await AppraisalService.RejectAsync(_detail!.Id, _supervisorNote, ResolveActorName());
        await CloseDialogs();
        NavigationManager.NavigateTo(NavigationManager.ToAppPath(AppRoutes.PencarianData.Detail(PublicId.ToString("D"))), forceLoad: true);
    }

    private string GetBackHref() => IsInquiryRoute ? AppRoutes.Inquiry.Main : AppRoutes.PencarianData.Main;

    private string GetEditHref() => AppRoutes.PencarianData.Edit(PublicId.ToString("D"));

    private string ResolveActorName()
    {
        var user = AuthenticationStateTask?.IsCompletedSuccessfully == true
            ? AuthenticationStateTask.Result.User
            : null;

        if (!string.IsNullOrWhiteSpace(user?.Identity?.Name))
        {
            return user.Identity.Name!;
        }

        return "System User";
    }

    private static string GetStatusVariant(AppraisalStatus status) => status switch
    {
        AppraisalStatus.Approved => "success",
        AppraisalStatus.Rejected => "danger",
        AppraisalStatus.Submitted => "warning",
        _ => "neutral"
    };

    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DisplayDate(DateTime? value) => value.HasValue ? value.Value.ToString("dd MMM yyyy").ToUpperInvariant() : "-";

    private static string DisplayDateTime(DateTime? value) => value.HasValue ? value.Value.ToString("dd MMM yyyy HH:mm").ToUpperInvariant() : "-";

    private static string DisplayNumber(decimal? value) => value.HasValue ? value.Value.ToString("N2") : "-";

    private static string FormatCurrency(decimal value) => value.ToString("N0");

    private static string FormatNullableCurrency(decimal? value) => value.HasValue ? value.Value.ToString("N0") : "-";

    private static string DisplayMeasurement(decimal? value) => value.HasValue ? $"{value.Value:N2} m2" : "-";

    private static string DisplayPercent(decimal? value) => value.HasValue ? $"{value.Value:N2}%" : "-";

    private static string GetApplicantLabel(ApplicantType applicantType)
        => applicantType == ApplicantType.Business ? "Badan Usaha" : "Perorangan";

    private static string GetCollateralLabel(CollateralType collateralType) => collateralType switch
    {
        CollateralType.Property => "Property",
        CollateralType.Vehicle => "Vehicle",
        CollateralType.Machine => "Machine",
        CollateralType.Inventory => "Inventory",
        _ => "Other"
    };

    private static string BuildAddress(AppraisalDetailDto detail)
    {
        var parts = new[]
        {
            detail.AddressLine1,
            detail.AddressLine2,
            detail.AddressLine3,
            BuildRtRw(detail),
            detail.Subdistrict,
            detail.District,
            detail.City,
            detail.Province,
            detail.PostalCode,
            detail.Country
        }
        .Where(x => !string.IsNullOrWhiteSpace(x));

        var address = string.Join(", ", parts);
        return string.IsNullOrWhiteSpace(address) ? "-" : address;
    }

    private static string BuildSubArea(AppraisalDetailDto detail)
    {
        var value = string.Join(" / ", new[] { detail.Subdistrict, detail.District }.Where(x => !string.IsNullOrWhiteSpace(x)));
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string BuildCityArea(AppraisalDetailDto detail)
    {
        var value = string.Join(" / ", new[] { detail.City, detail.Province }.Where(x => !string.IsNullOrWhiteSpace(x)));
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string BuildRtRw(AppraisalDetailDto detail)
    {
        if (string.IsNullOrWhiteSpace(detail.Rt) && string.IsNullOrWhiteSpace(detail.Rw))
        {
            return string.Empty;
        }

        return $"RT {Display(detail.Rt)} / RW {Display(detail.Rw)}";
    }

    private static (string Notes, List<ComparableDetail> Comparables) ParseComparableSection(string? rawNotes)
    {
        var value = rawNotes ?? string.Empty;
        var markerIndex = value.IndexOf(ComparableMarker, StringComparison.Ordinal);

        if (markerIndex < 0)
        {
            return (value, []);
        }

        var plainNotes = value[..markerIndex].TrimEnd();
        var json = value[(markerIndex + ComparableMarker.Length)..].Trim();

        if (string.IsNullOrWhiteSpace(json))
        {
            return (plainNotes, []);
        }

        try
        {
            var comparables = System.Text.Json.JsonSerializer.Deserialize<List<ComparableDetail>>(json) ?? [];
            return (plainNotes, comparables);
        }
        catch
        {
            return (value, []);
        }
    }

    private sealed class ComparableDetail
    {
        public string Source { get; set; } = string.Empty;
        public string Location { get; set; } = string.Empty;
        public string Specification { get; set; } = string.Empty;
        public decimal? LandArea { get; set; }
        public decimal? BuildingArea { get; set; }
        public decimal? OfferPrice { get; set; }
        public decimal? AdjustmentPercent { get; set; }
        public decimal? IndicatedValue { get; set; }
        public string Remarks { get; set; } = string.Empty;
    }
}
