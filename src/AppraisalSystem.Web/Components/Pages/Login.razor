@page "/login"
@layout EmptyLayout
@inject Microsoft.Extensions.Options.IOptionsMonitor<AppraisalSystem.Web.Options.ThemeOptions> ThemeOptionsAccessor
@inject NavigationManager NavigationManager

<PageTitle>Login - Appraisal System</PageTitle>

<div class="auth-split">
    <section class="auth-left">
        <div class="auth-left__inner">
            <div class="auth-brand">@BrandName</div>
            <h1 class="auth-title">Welcome Back</h1>
            <p class="auth-subtitle">Masuk ke sistem appraisal internal untuk melanjutkan workflow penilaian agunan.</p>

            <form action="@LoginPostAction" method="post" class="auth-form">
                <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                <BasePlainTextField Id="username"
                                    Label="Username"
                                    Name="username"
                                    Placeholder="Masukkan username"
                                    Required="true"
                                    InputClass="auth-control" />

                <BasePlainTextField Id="password"
                                    Label="Password"
                                    Type="password"
                                    Name="password"
                                    Placeholder="Masukkan password"
                                    Required="true"
                                    InputClass="auth-control" />

                <div class="auth-row-help">
                    <BaseCheckboxField Label="Remember me" Class="remember-wrap" />
                    <a href="#" @onclick="PreventLinkNavigation">Forgot password</a>
                </div>

                @if (ShowError)
                {
                    <BaseAlert Variant="danger">
                        Username atau password salah.
                    </BaseAlert>
                }

                <BaseButton ButtonType="submit" Variant="brand" FullWidth="true" Class="auth-submit">Sign in</BaseButton>
            </form>

            <div class="auth-demo">
                <strong>Demo akun:</strong>
                <span>admin/admin123</span>
                <span>appraiser/appraiser123</span>
                <span>supervisor/supervisor123</span>
            </div>
        </div>
    </section>

    <section class="auth-right" aria-hidden="true" style="@AuthRightStyle">
        <div class="auth-right__overlay"></div>

        @if (HasLogoPath)
        {
            <div class="auth-right__brand-logo" role="presentation">
                <img src="@ResolvedLogoPath" alt="@BrandName logo" loading="lazy" />
            </div>
        }

        <div class="auth-right__content">
            <h2>Precision in Every Valuation</h2>
            <p>Review asset data, monitor approval status, and keep appraisal decisions traceable in one secure dashboard.</p>

            <div class="auth-stat-grid">
                <div>
                    <span>Workflow</span>
                    <strong>Appraiser -> Supervisor</strong>
                </div>
                <div>
                    <span>Security</span>
                    <strong>Role Based Access</strong>
                </div>
                <div>
                    <span>Scalable Data</span>
                    <strong>Multi Database Provider</strong>
                </div>
            </div>
        </div>

        <div class="auth-orb auth-orb--one"></div>
        <div class="auth-orb auth-orb--two"></div>
        <div class="auth-orb auth-orb--three"></div>
    </section>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private AppraisalSystem.Web.Options.ThemeOptions Theme => ThemeOptionsAccessor.CurrentValue;

    private string BrandName => string.IsNullOrWhiteSpace(Theme.BrandName) ? "RDS Appraisal" : Theme.BrandName;

    private bool HasLogoPath => !string.IsNullOrWhiteSpace(Theme.LogoPath);

    private string LoginPostAction => ResolveAppRoute(AppRoutes.Account.LoginPost);

    private string ResolvedLogoPath => ResolveAssetUrl(Theme.LogoPath);

    private string AuthRightStyle
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Theme.LoginHeroImageUrl))
            {
                return string.Empty;
            }

            var heroImageUrl = ResolveAssetUrl(Theme.LoginHeroImageUrl);
            return $"background-image: linear-gradient(135deg, rgba(8, 21, 38, 0.72) 0%, rgba(11, 41, 74, 0.88) 60%, rgba(20, 65, 110, 0.95) 100%), url('{heroImageUrl}'); background-size: cover; background-position: center;";
        }
    }

    private bool ShowError => string.Equals(Error, "1", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        ReturnUrl = string.IsNullOrWhiteSpace(ReturnUrl) ? ResolveAppRoute(AppRoutes.Dashboard.Main) : ReturnUrl;
    }

    private void PreventLinkNavigation(MouseEventArgs _)
    {
    }

    private string ResolveAssetUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return string.Empty;
        }

        if (Uri.TryCreate(path, UriKind.Absolute, out _)
            || path.StartsWith("data:", StringComparison.OrdinalIgnoreCase))
        {
            return path;
        }

        var normalizedPath = path.StartsWith("~/", StringComparison.Ordinal)
            ? path[2..]
            : path.TrimStart('/');

        return new Uri(new Uri(NavigationManager.BaseUri), normalizedPath).ToString();
    }

    private string ResolveAppRoute(string route)
    {
        var normalizedRoute = route.StartsWith("/", StringComparison.Ordinal) ? route[1..] : route;
        return new Uri(new Uri(NavigationManager.BaseUri), normalizedRoute).PathAndQuery;
    }
}
